{
  "name": "bluepencil",
  "version": "0.1.0",
  "private": true,
  "description": "A personal macOS writing assistant — on-demand proofreading, rewriting and tone adjustment powered by an LLM you supply the key for.",
  "license": "UNLICENSED",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "test": "node --test test/",
    "typecheck": "tsc -p tsconfig.json",
    "lint": "eslint .",
    "verify": "npm run typecheck && npm run lint && node scripts/secret-scan.mjs && npm test && npm run build",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "rebuild": "electron-rebuild -f -w keytar",
    "helper:build": "xcrun swiftc -O helper/ax-probe.swift -o helper/ax-probe",
    "prepare": "node scripts/setup-hooks.mjs",
    "postinstall": "electron-builder install-app-deps",
    "dist": "electron-vite build && electron-builder --mac"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.69.0",
    "dompurify": "^3.4.10",
    "keytar": "^7.9.0",
    "lucide-react": "^0.460.0",
    "marked": "^18.0.5",
    "openai": "^4.77.0",
    "turndown": "^7.2.4"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.0",
    "@types/node": "^20.19.43",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "eslint": "^9.39.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.9.3",
    "vite": "^5.4.11"
  },
  "build": {
    "appId": "app.bluepencil.mac",
    "productName": "Blue Pencil",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "mac": {
      "icon": "build/icon.icns",
      "category": "public.app-category.productivity",
      "extendInfo": {
        "LSUIElement": true
      },
      "target": [
        "dmg"
      ],
      "identity": null,
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist"
    }
  }
}
