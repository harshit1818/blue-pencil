{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "checkJs": true,
    "noEmit": true,
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "noImplicitAny": false,
    "resolveJsonModule": true,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@tokens": ["src/shared/tokens.js"]
    }
  },
  "include": ["src/**/*.js", "src/**/*.jsx", "test/**/*.mjs", "types/**/*.d.ts"],
  "exclude": ["node_modules", "out", "dist"]
}
