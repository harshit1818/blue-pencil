#!/usr/bin/env bash
# Blocks any commit whose `verify` gate is red. This is the harness-level gate the
# loop relied on prose for (PROMPT_build.md): a fresh agent can no longer commit a
# board flip or a broken fix past a red gate. Humans bypass with `git commit -n`.
set -euo pipefail
cd "$(git rev-parse --show-toplevel)"
echo "pre-commit: running npm run verify (bypass with git commit -n)…" >&2
exec npm run --silent verify 1>&2
